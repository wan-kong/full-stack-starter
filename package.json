{
	"name": "auth-provider",
	"version": "0.0.1",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@better-auth/api-key": "1.6.0",
			"typescript": "^5",
			"@types/bun": "^1.3.4",
			"lucide-react": "1.8.0",
			"@types/react": "19.2.14",
			"@types/react-dom": "19.2.3",
			"next-themes": "0.4.6",
			"react": "19.2.5",
			"next": "^16.2.0",
			"react-dom": "19.2.5",
			"sonner": "2.0.7",
			"@prisma/client": "^7.2.0",
			"@tailwindcss/postcss": "^4.1.18",
			"elysia": "^1.4.21",
			"tailwindcss": "4.2.2",
			"better-auth": "^1.6.0"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"auth:generate": "turbo -F @auth-provider/server auth:generate",
		"dev:server": "turbo -F @auth-provider/server dev",
		"db:studio": "turbo -F @auth-provider/db db:studio",
		"db:generate": "turbo -F @auth-provider/db db:generate",
		"db:migrate": "turbo -F @auth-provider/db db:migrate",
		"check": "ultracite check",
		"fix": "ultracite fix",
		"release": "bumpp"
	},
	"dependencies": {
		"@auth-provider/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@auth-provider/config": "workspace:*",
		"@biomejs/biome": "2.4.9",
		"@types/bun": "catalog:",
		"bumpp": "^11.0.1",
		"turbo": "^2.8.12",
		"portless": "0.10.3",
		"typescript": "catalog:",
		"ultracite": "7.4.2"
	},
	"packageManager": "bun@1.3.5"
}

{
  "name": "auth-provider",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "elysia": "^1.4.21",
      "@trpc/server": "^11.13.4",
      "better-auth": "1.5.5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @auth-provider/db db:push",
    "db:studio": "turbo -F @auth-provider/db db:studio",
    "db:generate": "turbo -F @auth-provider/db db:generate",
    "db:migrate": "turbo -F @auth-provider/db db:migrate",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@auth-provider/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@auth-provider/config": "workspace:*",
    "@biomejs/biome": "2.4.9",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.4.2"
  },
  "packageManager": "bun@1.3.5"
}
